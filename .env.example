# Database
DATABASE_URL=sqlite:///./cognidata.db

# Backup
BACKUP_DIR=./backups

# ==============================================================================
# CRITICAL: Authentication & Security Settings
# These environment variables MUST be set before running CogniData in production
# ==============================================================================

# JWT Secret Key - REQUIRED - Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Must be at least 32 characters for security
AUTH_SECRET_KEY=your_secure_jwt_secret_key_here_min_32_chars

# Admin Password - REQUIRED - Set to a strong password before first startup
# Requirements: 12+ characters, mixed case, numbers, special characters
# Example: export ADMIN_PASSWORD='MySecurePass123!'
ADMIN_PASSWORD=your_secure_admin_password_here

# Data Encryption Key - OPTIONAL but recommended for production
# Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Used for encrypting sensitive data at rest (test results, backups)
DATA_ENCRYPTION_KEY=

# ==============================================================================
# Production Security Checklist
# ==============================================================================
# Before deploying to production:
# [ ] Set AUTH_SECRET_KEY to a random 32+ character string
# [ ] Set ADMIN_PASSWORD to a secure, unique password
# [ ] Set DATA_ENCRYPTION_KEY for at-rest encryption
# [ ] Deploy behind HTTPS (TLS 1.2+)
# [ ] Use HTTPS proxy (nginx, Apache, AWS ALB, etc.)
# [ ] Enable CSRF protection at reverse proxy level
# [ ] Implement rate limiting (fail2ban, AWS WAF, Cloudflare)
# [ ] Enable database encryption (PostgreSQL pgcrypto)
# [ ] Use secure secret management (AWS Secrets Manager, Azure Key Vault)
# [ ] Monitor and audit all authentication events
# [ ] Implement regular backups with encryption
# [ ] Regular security patches and dependency updates

